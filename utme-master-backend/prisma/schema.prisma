generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String            @id @default(cuid())
  email                 String            @unique
  password              String
  role                  UserRole          @default(STUDENT)
  phone                 String?           @unique
  createdAt             DateTime          @default(now())
  firstName             String
  isActive              Boolean           @default(true)
  lastLogin             DateTime?
  lastName              String
  licenseExpiresAt      DateTime?
  licenseId             String?
  licenseTier           LicenseTier       @default(TRIAL)
  updatedAt             DateTime          @updatedAt
  resetToken            String?
  resetTokenExpires     DateTime?
  createdExams          Exam[]            @relation("ExamCreator")
  notifications         Notification[]    @relation("UserNotifications")
  createdQuestions      Question[]        @relation("QuestionCreator")
  studentExams          StudentExam[]     @relation("StudentExams")
  studentProgress       StudentProgress[]
  systemSettingsUpdates SystemSettings[]  @relation("SettingsUpdater")
  license               License?          @relation(fields: [licenseId], references: [id])
  questionImports       QuestionImport[]  @relation("QuestionImporter")
  auditLogs             AuditLog[]        @relation("AuditUser")

  @@index([email])
  @@index([role])
  @@index([licenseTier])
  @@map("users")
}

model Exam {
  id                  String         @id @default(cuid())
  title               String
  description         String?
  duration            Int
  difficulties        Json?
  allowRetake         Boolean        @default(false)
  allowReview         Boolean        @default(true)
  createdAt           DateTime       @default(now())
  createdBy           String
  endsAt              DateTime?
  isActive            Boolean        @default(true)
  isPublished         Boolean        @default(false)
  passMarks           Int
  questionsPerSubject Json?
  randomizeOptions    Boolean        @default(false)
  randomizeQuestions  Boolean        @default(false)
  showResults         Boolean        @default(true)
  startsAt            DateTime?
  subjectIds          Json
  totalMarks          Int
  totalQuestions      Int
  updatedAt           DateTime       @updatedAt
  yearFrom            Int?
  yearTo              Int?
  examQuestions       ExamQuestion[]
  creator             User           @relation("ExamCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  notifications       Notification[] @relation("ExamNotifications")
  studentExams        StudentExam[]

  @@index([createdBy])
  @@index([isPublished, isActive])
  @@index([createdAt])
  @@map("exams")
}

model ExamQuestion {
  id           String   @id @default(cuid())
  points       Int      @default(1)
  createdAt    DateTime @default(now())
  examId       String
  orderNumber  Int
  questionData Json
  questionId   String
  exam         Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([examId, questionId])
  @@index([examId])
  @@index([questionId])
  @@map("exam_questions")
}

model StudentExam {
  id                String          @id @default(cuid())
  status            ExamStatus      @default(NOT_STARTED)
  score             Float           @default(0)
  passed            Boolean?
  grade             String?
  answeredQuestions Int             @default(0)
  autoSubmitted     Boolean         @default(false)
  correctAnswers    Int             @default(0)
  createdAt         DateTime        @default(now())
  examId            String
  questionOrder     Json
  startedAt         DateTime?
  studentId         String
  submittedAt       DateTime?
  timeRemaining     Int?
  timeSpent         Int             @default(0)
  totalQuestions    Int
  totalScore        Float           @default(0)
  updatedAt         DateTime        @updatedAt
  wrongAnswers      Int             @default(0)
  isPractice        Boolean         @default(false)
  answers           StudentAnswer[]
  exam              Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  student           User            @relation("StudentExams", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
  @@index([status])
  @@index([studentId, status])
  @@index([isPractice])
  @@index([createdAt])
  @@map("student_exams")
}

model StudentAnswer {
  id               String      @id @default(cuid())
  answer           Json?
  answeredAt       DateTime?
  createdAt        DateTime    @default(now())
  flaggedForReview Boolean     @default(false)
  isCorrect        Boolean?
  pointsEarned     Float       @default(0)
  questionId       String
  studentExamId    String
  timeSpent        Int?
  updatedAt        DateTime    @updatedAt
  question         Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  studentExam      StudentExam @relation(fields: [studentExamId], references: [id], onDelete: Cascade)

  @@unique([studentExamId, questionId])
  @@index([studentExamId])
  @@index([questionId])
  @@map("student_answers")
}

model Question {
  id               String          @id @default(cuid())
  options          Json
  explanation      String?
  images           Json?
  points           Int             @default(1)
  difficulty       Difficulty
  year             Int?
  allowMultiple    Boolean         @default(false)
  audioUrl         String?
  correctAnswer    String?
  createdAt        DateTime        @default(now())
  createdBy        String
  examType         ExamType        @default(JAMB)
  isActive         Boolean         @default(true)
  questionText     String
  questionType     QuestionType    @default(MCQ)
  subjectId        String
  timeLimitSeconds Int?
  topicId          String?
  updatedAt        DateTime        @updatedAt
  videoUrl         String?
  examQuestions    ExamQuestion[]
  creator          User            @relation("QuestionCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  subject          Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic            Topic?          @relation(fields: [topicId], references: [id])
  studentAnswers   StudentAnswer[]

  @@index([createdBy])
  @@index([difficulty])
  @@index([examType])
  @@index([subjectId])
  @@index([subjectId, difficulty])
  @@index([year])
  @@map("questions")
}

model Subject {
  id              String            @id @default(cuid())
  name            String            @unique
  code            String            @unique
  description     String?
  createdAt       DateTime          @default(now())
  isActive        Boolean           @default(true)
  updatedAt       DateTime          @updatedAt
  questions       Question[]
  studentProgress StudentProgress[]
  topics          Topic[]

  @@index([code])
  @@map("subjects")
}

model Topic {
  id          String     @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime   @default(now())
  isActive    Boolean    @default(true)
  subjectId   String
  updatedAt   DateTime   @updatedAt
  questions   Question[]
  subject     Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([name, subjectId])
  @@index([subjectId])
  @@map("topics")
}

model StudentProgress {
  id               String    @id @default(cuid())
  averageScore     Float     @default(0)
  correctAnswers   Int       @default(0)
  createdAt        DateTime  @default(now())
  lastPracticeDate DateTime?
  studentId        String
  subjectId        String
  totalQuestions   Int       @default(0)
  updatedAt        DateTime  @updatedAt
  wrongAnswers     Int       @default(0)
  student          User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject          Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
  @@index([studentId])
  @@index([subjectId])
  @@map("student_progress")
}

model License {
  id                  String              @id @default(cuid())
  tier                LicenseTier         @default(TRIAL)
  status              LicenseStatus       @default(ACTIVE)
  features            Json                @default("{}")
  notes               String?
  activatedAt         DateTime?
  autoRenew           Boolean             @default(false)
  contactEmail        String?
  contactPhone        String?
  createdAt           DateTime            @default(now())
  currentQuestions    Int                 @default(0)
  currentStudents     Int                 @default(0)
  expiryDate          DateTime?
  hardwareFingerprint String?             @unique
  isActivated         Boolean             @default(false)
  lastRenewalDate     DateTime?
  licenseKey          String              @unique
  maxQuestions        Int                 @default(500)
  maxStudents         Int                 @default(50)
  organizationName    String?
  purchaseDate        DateTime?
  trialEndDate        DateTime?
  trialStartDate      DateTime?
  updatedAt           DateTime            @updatedAt
  activations         LicenseActivation[]
  users               User[]

  @@index([licenseKey])
  @@index([status])
  @@index([tier])
  @@index([hardwareFingerprint])
  @@map("licenses")
}

model LicenseActivation {
  id                  String   @id @default(cuid())
  success             Boolean  @default(true)
  action              String
  computerName        String?
  cpuId               String
  createdAt           DateTime @default(now())
  errorMessage        String?
  hardwareFingerprint String
  ipAddress           String?
  licenseId           String
  macAddress          String
  motherboardSerial   String
  osVersion           String?
  license             License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@index([licenseId])
  @@index([hardwareFingerprint])
  @@map("license_activations")
}

model SystemSettings {
  id                  String   @id @default(cuid())
  siteName            String   @default("UTME Master")
  siteDescription     String   @default("Professional UTME Examination System")
  maintenanceMode     Boolean  @default(false)
  maxUploadSize       Int      @default(5)
  sessionTimeout      Int      @default(30)
  timezone            String   @default("Africa/Lagos")
  enableTwoFactor     Boolean  @default(true)
  passwordMinLength   Int      @default(8)
  passwordExpiry      Int      @default(90)
  maxLoginAttempts    Int      @default(5)
  lockoutDuration     Int      @default(15)
  enableAuditLog      Boolean  @default(true)
  enableNotifications Boolean  @default(true)
  smtpHost            String   @default("smtp.gmail.com")
  smtpPort            Int      @default(587)
  smtpUsername        String   @default("")
  smtpPassword        String   @default("")
  fromEmail           String   @default("noreply@utmemaster.com")
  updatedBy           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  updatedByUser       User     @relation("SettingsUpdater", fields: [updatedBy], references: [id])

  @@map("system_settings")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType @default(INFO)
  title     String
  message   String
  userId    String
  examId    String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  exam      Exam?            @relation("ExamNotifications", fields: [examId], references: [id], onDelete: Cascade)
  user      User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([examId])
  @@index([createdAt])
  @@map("notifications")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ExamStatus {
  NOT_STARTED
  IN_PROGRESS
  PAUSED
  SUBMITTED
  EXPIRED
  GRADING
}

enum ExamType {
  JAMB
  WAEC
  NECO
  MOCK
  PRACTICE
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  REVOKED
}

enum LicenseTier {
  TRIAL
  BASIC
  PREMIUM
  ENTERPRISE
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  FILL_BLANK
  ESSAY
  MATCHING
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
  SUPER_ADMIN
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
  EXAM_START
  EXAM_END
  SYSTEM_MAINTENANCE
}

// ==========================================
// QUESTION IMPORT - tracks bulk import jobs
// ==========================================
model QuestionImport {
  id            String   @id @default(cuid())
  fileName      String
  totalRows     Int      @default(0)
  imported      Int      @default(0)
  skipped       Int      @default(0)
  failed        Int      @default(0)
  status        String   @default("PENDING") // PENDING | PROCESSING | DONE | FAILED
  errorLog      Json?    // Array of { row, error }
  importedBy    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  importer      User     @relation("QuestionImporter", fields: [importedBy], references: [id], onDelete: Cascade)

  @@index([importedBy])
  @@index([status])
  @@map("question_imports")
}

// ==========================================
// FLAGGED QUESTIONS - persists student flag reports
// ==========================================
model FlaggedQuestion {
  id            String   @id @default(cuid())
  studentExamId String
  examId        String
  questionId    String
  studentId     String
  reason        String?
  status        String   @default("PENDING") // PENDING | REVIEWED | DISMISSED
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([examId])
  @@index([questionId])
  @@index([studentId])
  @@index([status])
  @@index([createdAt])
  @@map("flagged_questions")
}

// ==========================================
// AUDIT LOG - tracks all admin/teacher actions
// ==========================================
model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // CREATE_QUESTION | UPDATE_QUESTION | DELETE_QUESTION | CREATE_EXAM | etc.
  entityType String   // question | exam | user | subject
  entityId   String?
  oldData    Json?    // snapshot before change
  newData    Json?    // snapshot after change
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User     @relation("AuditUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

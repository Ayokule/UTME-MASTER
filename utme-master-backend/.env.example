# ==========================================
# ENVIRONMENT VARIABLES (Template)
# ==========================================
# Environment variables are settings that change based on where the app runs
# (development on your computer vs production on a server)
#
# IMPORTANT: Copy this file to .env and fill in your actual values
# Command: cp .env.example .env
#
# NEVER commit .env to git (it contains secrets!)

# ==========================================
# NODE ENVIRONMENT
# ==========================================
# Tells the app whether it's running in development or production
# Options: development, production, test
NODE_ENV=development

# PORT: Which port the server listens on
# Think of a port like an apartment number in a building
# Default: 3000 (common for development)
PORT=3000

# ==========================================
# DATABASE CONNECTION
# ==========================================
# PostgreSQL connection string
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
#
# Breakdown:
# - USERNAME: Your PostgreSQL username (default: postgres)
# - PASSWORD: Your PostgreSQL password (set during installation)
# - HOST: Where database is running (localhost = your computer)
# - PORT: PostgreSQL port (default: 5432)
# - DATABASE_NAME: Name of your database (utme_master)
#
# Example for local development:
DATABASE_URL=postgresql://postgres:12345@localhost:5432/utme_master

# ==========================================
# JWT (JSON WEB TOKEN) SECRETS
# ==========================================
# JWT is used for authentication (keeping users logged in)
# These secrets are used to sign and verify tokens
#
# IMPORTANT: Change these to random strings in production!
# You can generate random strings using: openssl rand -base64 32
#
# JWT_SECRET: Main secret for access tokens
# Make this long and random! At least 32 characters
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-make-it-very-long-and-random

# JWT_EXPIRES_IN: How long until token expires
# Options: 1h (1 hour), 7d (7 days), 30d (30 days)
# Shorter = more secure, but users must login more often
JWT_EXPIRES_IN=7d

# JWT_REFRESH_SECRET: Secret for refresh tokens
# Refresh tokens let users stay logged in longer
JWT_REFRESH_SECRET=your-super-secret-refresh-key-also-change-this-make-it-different-from-jwt-secret

# JWT_REFRESH_EXPIRES_IN: How long refresh tokens last
JWT_REFRESH_EXPIRES_IN=30d

# ==========================================
# CORS (Cross-Origin Resource Sharing)
# ==========================================
# CORS controls which websites can access your API
# This prevents random websites from stealing data
#
# CORS_ORIGIN: Which frontend URL is allowed to connect
# In development: http://localhost:5173 (Vite default)
# In production: Your actual domain (e.g., http://192.168.1.100)
CORS_ORIGIN=http://localhost:5173

# ==========================================
# API SETTINGS
# ==========================================
# API_PREFIX: Prefix for all API routes
# All routes will be: http://localhost:3000/api/...
API_PREFIX=/api

# RATE_LIMIT_WINDOW_MS: Time window for rate limiting (milliseconds)
# 15 minutes = 15 * 60 * 1000 = 900000
RATE_LIMIT_WINDOW_MS=900000

# RATE_LIMIT_MAX_REQUESTS: Max requests per window
# Prevents abuse (someone spamming your API)
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# FILE UPLOAD SETTINGS
# ==========================================
# MAX_FILE_SIZE: Maximum upload size in bytes
# 5MB = 5 * 1024 * 1024 = 5242880 bytes
MAX_FILE_SIZE=5242880

# UPLOAD_DIR: Where to store uploaded files
# This folder will contain question images, etc.
UPLOAD_DIR=./uploads

# ==========================================
# LOGGING
# ==========================================
# LOG_LEVEL: How much detail in logs
# Options: error (least), warn, info, debug (most)
LOG_LEVEL=info

# ==========================================
# HOW TO USE THIS FILE
# ==========================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values (especially DATABASE_URL password)
# 3. Never commit .env to git (it's in .gitignore)
# 4. Access in code: process.env.DATABASE_URL
#
# Example:
# const dbUrl = process.env.DATABASE_URL
# const port = process.env.PORT || 3000
